rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return true; // request.auth != null; - Temporarily allow for testing
    }

    function isEmailVerified() {
      return true; // isSignedIn() && request.auth.token.email_verified == true; - Temporarily allow
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Products ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'price', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.category is string &&
             data.price is number && data.price >= 0 &&
             data.stock is number &&
             (data.keys().size() <= 12); // Increased for ingredients
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidProduct(incoming()) && incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'category', 'price', 'stock', 'sku', 'lowStockThreshold', 'imageUrl', 'ingredients', 'updatedAt']) &&
        incoming().updatedAt == request.time
      );
      allow delete: if isEmailVerified();
    }

    // --- Raw Materials ---
    function isValidRawMaterial(data) {
      return data.keys().hasAll(['name', 'stock', 'unit']) &&
             data.name is string && data.name.size() > 0 &&
             data.stock is number &&
             data.unit is string &&
             (data.keys().size() <= 6);
    }

    match /rawMaterials/{materialId} {
      allow read: if true;
      allow create: if isEmailVerified() && isValidRawMaterial(incoming()) && incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && isValidRawMaterial(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'stock', 'unit', 'lowStockThreshold', 'updatedAt']) &&
        incoming().updatedAt == request.time
      );
      allow delete: if isEmailVerified();
    }

    // --- Categories ---
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEmailVerified();
    }

    // --- Orders ---
    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'total', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.total is number && data.total >= 0 &&
             data.createdAt == request.time;
    }

    match /orders/{orderId} {
      allow read: if true;
      allow list: if true;
      allow create: if isEmailVerified() && isValidOrder(incoming());
    }

    // --- Users ---
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
